let siteContentData = {};

async function loadSiteContentForEdit() {
    showStatus('Loading site content...', 'blue');
    try {
        const response = await fetch(`https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/main/content.json`);
        if (!response.ok) throw new Error('Failed to load');
        
        siteContentData = await response.json();
        
        const editor = document.getElementById('site-content-editor');
        editor.innerHTML = `
            <div class="space-y-4 mt-4">
                <div>
                    <label class="text-xs text-gray-500">Site Name</label>
                    <input type="text" id="site-name" value="${siteContentData.site.name}" class="form-input">
                </div>
                <div>
                    <label class="text-xs text-gray-500">Phone</label>
                    <input type="text" id="site-phone" value="${siteContentData.site.phone}" class="form-input">
                </div>
                <div>
                    <label class="text-xs text-gray-500">Email</label>
                    <input type="text" id="site-email" value="${siteContentData.site.email}" class="form-input">
                </div>
                <div>
                    <label class="text-xs text-gray-500">Shipping & Returns Content</label>
                    <textarea id="page-shipping" class="form-input" rows="4">${siteContentData.pages.shipping.content}</textarea>
                </div>
                <div>
                    <label class="text-xs text-gray-500">Our Story Content</label>
                    <textarea id="page-story" class="form-input" rows="4">${siteContentData.pages.story.content}</textarea>
                </div>
            </div>
        `;
        
        document.getElementById('save-site-btn').style.display = 'inline-block';
        showStatus('Site content loaded', 'green');
    } catch (error) {
        showStatus('Error loading site content: ' + error.message, 'red');
    }
}

async function saveSiteContent() {
    showStatus('Saving site content...', 'blue');
    
    // Update data from inputs
    siteContentData.site.name = document.getElementById('site-name').value;
    siteContentData.site.phone = document.getElementById('site-phone').value;
    siteContentData.site.email = document.getElementById('site-email').value;
    siteContentData.pages.shipping.content = document.getElementById('page-shipping').value;
    siteContentData.pages.story.content = document.getElementById('page-story').value;
    
    try {
        const getResponse = await fetch(`https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/contents/content.json`, {
            headers: {
                'Authorization': `token ${githubToken}`,
                'Accept': 'application/vnd.github.v3+json'
            }
        });
        
        const fileData = await getResponse.json();
        const sha = fileData.sha;
        
        const content = btoa(JSON.stringify(siteContentData, null, 2));
        
        const updateResponse = await fetch(`https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/contents/content.json`, {
            method: 'PUT',
            headers: {
                'Authorization': `token ${githubToken}`,
                'Accept': 'application/vnd.github.v3+json',
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                message: 'Update site content via CMS',
                content: content,
                sha: sha
            })
        });
        
        if (updateResponse.ok) {
            showStatus('✅ Site content saved!', 'green');
        } else {
            throw new Error('Failed to save');
        }
    } catch (error) {
        showStatus('❌ Error: ' + error.message, 'red');
    }
}
